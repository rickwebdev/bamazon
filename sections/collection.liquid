{% comment %}
  Collection / category listing — Bamazon marketplace styling.
{% endcomment %}

<div class="bam-page bam-collection full-width">
  <div class="bam-page__inner">
    <nav class="bam-breadcrumb bam-breadcrumb--bar" aria-label="Breadcrumb">
      <a class="bam-breadcrumb__link" href="{{ routes.root_url }}">{{ 'breadcrumbs.home' | t }}</a>
      <span class="bam-breadcrumb__sep" aria-hidden="true">›</span>
      <span class="bam-breadcrumb__current">{{ collection.title | escape }}</span>
    </nav>

    <header class="bam-collection__header">
      <h1 class="bam-collection__title">{{ collection.title | escape }}</h1>
      {% if collection.description != blank %}
        <div class="bam-collection__desc rte">{{ collection.description }}</div>
      {% endif %}
      <p class="bam-collection__count">
        {{ collection.products_count }}
        {% if collection.products_count == 1 %}item{% else %}items{% endif %}
      </p>
    </header>

    {% paginate collection.products by 24 %}
      {% if collection.products.size == 0 %}
        <div class="bam-collection__empty">
          <p>No products in this collection yet.</p>
          <a class="bam-btn bam-btn--primary" href="{{ routes.root_url }}">Back to home</a>
        </div>
      {% else %}
        <ul class="bam-collection__grid" role="list">
          {% for product in collection.products %}
            <li class="bam-collection__card">
              <a class="bam-collection__card-link" href="{{ product.url }}">
                <div class="bam-collection__media">
                  {% if product.featured_image %}
                    {% liquid
                      assign card_alt = product.featured_image.alt | default: product.title
                    %}
                    {{
                      product.featured_image
                      | image_url: width: 600, height: 600, crop: 'center'
                      | image_tag:
                        loading: 'lazy',
                        alt: card_alt,
                        class: 'bam-collection__img',
                        widths: '200, 400, 600',
                        sizes: '(min-width: 900px) 220px, (min-width: 600px) 33vw, 50vw'
                    }}
                  {% else %}
                    <div class="bam-collection__placeholder" aria-hidden="true"></div>
                  {% endif %}
                </div>
                <div class="bam-collection__meta">
                  <h2 class="bam-collection__product-title">{{ product.title | escape }}</h2>
                  <div class="bam-collection__price-row">
                    {% if product.compare_at_price > product.price %}
                      <span class="bam-collection__price bam-collection__price--sale">{{ product.price | money }}</span>
                      <span class="bam-collection__compare">{{ product.compare_at_price | money }}</span>
                    {% else %}
                      <span class="bam-collection__price">{{ product.price | money }}</span>
                    {% endif %}
                  </div>
                  {% if product.available == false %}
                    <span class="bam-collection__badge">Out of stock</span>
                  {% endif %}
                </div>
              </a>
            </li>
          {% endfor %}
        </ul>

        {% if paginate.pages > 1 %}
          <nav class="bam-pagination" aria-label="Pagination">
            {{ paginate | default_pagination }}
          </nav>
        {% endif %}
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% stylesheet %}
  .bam-page {
    background: #eaeded;
    padding: 1rem 0 3rem;
    width: 100%;
  }

  .bam-page__inner {
    max-width: min(1500px, 100%);
    margin: 0 auto;
    padding: 0 clamp(12px, 2vw, 24px);
  }

  .bam-breadcrumb {
    font-size: 0.8125rem;
    color: #565959;
    margin-bottom: 1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .bam-breadcrumb--bar {
    background: #fff;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    border: 1px solid #d5d9d9;
    box-shadow: 0 1px 2px rgba(15, 17, 17, 0.08);
    margin-bottom: 1.25rem;
  }

  .bam-breadcrumb__link {
    color: #007185;
    text-decoration: none;
  }

  .bam-breadcrumb__link:hover {
    color: #c7511f;
    text-decoration: underline;
  }

  .bam-breadcrumb__sep {
    color: #949494;
    user-select: none;
  }

  .bam-breadcrumb__current {
    color: #0f1111;
    font-weight: 500;
  }

  .bam-collection__header {
    margin-bottom: 1.25rem;
  }

  .bam-collection__title {
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 700;
    color: #0f1111;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .bam-collection__desc {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #565959;
    max-width: 70ch;
    margin-bottom: 0.5rem;
  }

  .bam-collection__desc :first-child {
    margin-top: 0;
  }

  .bam-collection__count {
    font-size: 0.8125rem;
    color: #767676;
    margin: 0;
  }

  .bam-collection__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .bam-collection__grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    }
  }

  .bam-collection__card {
    margin: 0;
  }

  .bam-collection__card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(15, 17, 17, 0.12);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .bam-collection__card-link:hover {
    box-shadow: 0 4px 12px rgba(15, 17, 17, 0.15);
    transform: translateY(-2px);
  }

  .bam-collection__media {
    aspect-ratio: 1;
    background: #f8f8f8;
    overflow: hidden;
  }

  .bam-collection__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background-color: #f0f0f0;
  }

  .bam-collection__placeholder {
    width: 100%;
    height: 100%;
    min-height: 160px;
    background: linear-gradient(145deg, #e3e6e6, #d5d9d9);
  }

  .bam-collection__meta {
    padding: 0.75rem 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .bam-collection__product-title {
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.35;
    color: #0f1111;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bam-collection__price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem;
    margin-top: auto;
  }

  .bam-collection__price {
    font-size: 1rem;
    font-weight: 700;
    color: #0f1111;
  }

  .bam-collection__price--sale {
    color: #b12704;
  }

  .bam-collection__compare {
    font-size: 0.8125rem;
    color: #565959;
    text-decoration: line-through;
  }

  .bam-collection__badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #565959;
  }

  .bam-collection__empty {
    background: #fff;
    border-radius: 8px;
    padding: 3rem 1.5rem;
    text-align: center;
    color: #565959;
    box-shadow: 0 1px 2px rgba(15, 17, 17, 0.1);
  }

  .bam-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 999px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .bam-btn--primary {
    background: #febd69;
    color: #0f1111;
    box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.08);
  }

  .bam-btn--primary:hover {
    background: #f3a847;
  }

  .bam-pagination {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  .bam-pagination :is(span, a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    min-height: 2.25rem;
    margin: 0 0.15rem;
    padding: 0 0.5rem;
    font-size: 0.875rem;
    border-radius: 4px;
    text-decoration: none;
  }

  .bam-pagination a {
    color: #007185;
    background: #fff;
    border: 1px solid #d5d9d9;
  }

  .bam-pagination a:hover {
    background: #f0f2f2;
  }

  .bam-pagination .current,
  .bam-pagination span.current {
    font-weight: 700;
    color: #0f1111;
    background: #fff;
    border: 1px solid #febd69;
  }

  .bam-pagination .deco {
    border: none;
    background: transparent;
    color: #565959;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
