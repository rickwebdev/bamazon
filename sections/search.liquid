{% comment %}
  Search results — Bamazon marketplace styling (matches collection grid).
{% endcomment %}

<div class="bam-page bam-search full-width">
  <div class="bam-page__inner">
    <nav class="bam-breadcrumb bam-breadcrumb--bar" aria-label="Breadcrumb">
      <a class="bam-breadcrumb__link" href="{{ routes.root_url }}">{{ 'breadcrumbs.home' | t }}</a>
      <span class="bam-breadcrumb__sep" aria-hidden="true">›</span>
      <span class="bam-breadcrumb__current">{{ 'search.title' | t }}</span>
    </nav>

    <header class="bam-search__header">
      <h1 class="bam-search__title">{{ 'search.title' | t }}</h1>
    </header>

    <form class="bam-search__form" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="bam-search-q">{{ 'search.title' | t }}</label>
      <div class="bam-search__field">
        <input
          id="bam-search-q"
          class="bam-search__input"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
        >
        <button class="bam-search__submit" type="submit">{{ 'search.submit' | t }}</button>
      </div>
    </form>

    {% if search.performed %}
      {% if search.results_count == 0 %}
        <div class="bam-search__empty">
          <p class="bam-search__empty-text">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
          <a class="bam-btn bam-btn--primary" href="{{ routes.root_url }}">{{ 'cart.continue_shopping' | t }}</a>
        </div>
      {% else %}
        <p class="bam-search__summary">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

        {% paginate search.results by 24 %}
          <ul class="bam-search__grid" role="list">
            {% for result in search.results %}
              {% liquid
                assign rs_type = result.object_type
                if rs_type == blank and result.price
                  assign rs_type = 'product'
                elsif rs_type == blank and result.author
                  assign rs_type = 'article'
                elsif rs_type == blank
                  assign rs_type = 'page'
                endif
              %}
              <li class="bam-search__card">
                {% case rs_type %}
                  {% when 'product' %}
                    <a class="bam-search__card-link" href="{{ result.url }}">
                      <div class="bam-search__media">
                        {% if result.featured_image %}
                          {% liquid
                            assign r_alt = result.featured_image.alt | default: result.title
                          %}
                          {{
                            result.featured_image
                            | image_url: width: 600, height: 600, crop: 'center'
                            | image_tag:
                              loading: 'lazy',
                              alt: r_alt,
                              class: 'bam-search__img',
                              widths: '200, 400, 600',
                              sizes: '(min-width: 900px) 220px, (min-width: 600px) 33vw, 50vw'
                          }}
                        {% else %}
                          <div class="bam-search__placeholder" aria-hidden="true"></div>
                        {% endif %}
                      </div>
                      <div class="bam-search__meta">
                        <h2 class="bam-search__item-title">{{ result.title | escape }}</h2>
                        <div class="bam-search__price-row">
                          {% if result.compare_at_price > result.price %}
                            <span class="bam-search__price bam-search__price--sale">{{ result.price | money }}</span>
                            <span class="bam-search__compare">{{ result.compare_at_price | money }}</span>
                          {% else %}
                            <span class="bam-search__price">{{ result.price | money }}</span>
                          {% endif %}
                        </div>
                        {% if result.available == false %}
                          <span class="bam-search__badge">{{ 'search.out_of_stock' | t }}</span>
                        {% endif %}
                      </div>
                    </a>
                  {% when 'article' %}
                    <a class="bam-search__card-link bam-search__card-link--text" href="{{ result.url }}">
                      <div class="bam-search__media bam-search__media--article">
                        {% if result.image %}
                          {{
                            result.image
                            | image_url: width: 600, height: 400, crop: 'center'
                            | image_tag:
                              loading: 'lazy',
                              alt: result.image.alt | default: result.title,
                              class: 'bam-search__img bam-search__img--wide',
                              widths: '200, 400, 600',
                              sizes: '(min-width: 900px) 220px, (min-width: 600px) 33vw, 50vw'
                          }}
                        {% else %}
                          <div class="bam-search__placeholder bam-search__placeholder--article" aria-hidden="true"></div>
                        {% endif %}
                      </div>
                      <div class="bam-search__meta">
                        <span class="bam-search__type">{{ 'search.result_article' | t }}</span>
                        <h2 class="bam-search__item-title">{{ result.title | escape }}</h2>
                      </div>
                    </a>
                  {% else %}
                    <a class="bam-search__card-link bam-search__card-link--text" href="{{ result.url }}">
                      <div class="bam-search__media">
                        <div class="bam-search__placeholder bam-search__placeholder--page" aria-hidden="true"></div>
                      </div>
                      <div class="bam-search__meta">
                        <span class="bam-search__type">{{ 'search.result_page' | t }}</span>
                        <h2 class="bam-search__item-title">{{ result.title | escape }}</h2>
                      </div>
                    </a>
                {% endcase %}
              </li>
            {% endfor %}
          </ul>

          {% if paginate.pages > 1 %}
            <nav class="bam-pagination" aria-label="Pagination">
              {{ paginate | default_pagination }}
            </nav>
          {% endif %}
        {% endpaginate %}
      {% endif %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .bam-page {
    background: #eaeded;
    padding: 1rem 0 3rem;
    width: 100%;
  }

  .bam-page__inner {
    max-width: min(1500px, 100%);
    margin: 0 auto;
    padding: 0 clamp(12px, 2vw, 24px);
  }

  .bam-breadcrumb {
    font-size: 0.8125rem;
    color: #565959;
    margin-bottom: 1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }

  .bam-breadcrumb--bar {
    background: #fff;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    border: 1px solid #d5d9d9;
    box-shadow: 0 1px 2px rgba(15, 17, 17, 0.08);
    margin-bottom: 1.25rem;
  }

  .bam-breadcrumb__link {
    color: #007185;
    text-decoration: none;
  }

  .bam-breadcrumb__link:hover {
    color: #c7511f;
    text-decoration: underline;
  }

  .bam-breadcrumb__sep {
    color: #949494;
    user-select: none;
  }

  .bam-breadcrumb__current {
    color: #0f1111;
    font-weight: 500;
  }

  .bam-search__header {
    margin-bottom: 1rem;
  }

  .bam-search__title {
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 700;
    color: #0f1111;
    margin: 0;
    line-height: 1.2;
  }

  .bam-search__form {
    margin-bottom: 1.5rem;
  }

  .bam-search__field {
    display: flex;
    max-width: 720px;
    height: 2.75rem;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 5px rgba(15, 17, 17, 0.12);
    border: 1px solid #d5d9d9;
  }

  .bam-search__input {
    flex: 1;
    border: none;
    padding: 0 1rem;
    font-size: 1rem;
    color: #0f1111;
    min-width: 0;
    background: #fff;
  }

  .bam-search__input:focus {
    outline: 2px solid #f3a847;
    outline-offset: -2px;
  }

  .bam-search__submit {
    flex: 0 0 auto;
    min-width: 5rem;
    border: none;
    background: #febd69;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0f1111;
    cursor: pointer;
    padding: 0 1.25rem;
  }

  .bam-search__submit:hover {
    background: #f3a847;
  }

  .bam-search__summary {
    font-size: 0.9375rem;
    color: #565959;
    margin: 0 0 1rem;
  }

  .bam-search__empty {
    background: #fff;
    border-radius: 8px;
    padding: 3rem 1.5rem;
    text-align: center;
    color: #565959;
    box-shadow: 0 1px 2px rgba(15, 17, 17, 0.1);
  }

  .bam-search__empty-text {
    margin: 0;
    font-size: 1rem;
  }

  .bam-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 999px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .bam-btn--primary {
    background: #febd69;
    color: #0f1111;
    box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.08);
  }

  .bam-btn--primary:hover {
    background: #f3a847;
  }

  .bam-search__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .bam-search__grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    }
  }

  .bam-search__card {
    margin: 0;
  }

  .bam-search__card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(15, 17, 17, 0.12);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .bam-search__card-link:hover {
    box-shadow: 0 4px 12px rgba(15, 17, 17, 0.15);
    transform: translateY(-2px);
  }

  .bam-search__media {
    aspect-ratio: 1;
    background: #f8f8f8;
    overflow: hidden;
  }

  .bam-search__media--article {
    aspect-ratio: 3 / 2;
  }

  .bam-search__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background-color: #f0f0f0;
  }

  .bam-search__img--wide {
    object-fit: cover;
  }

  .bam-search__placeholder {
    width: 100%;
    height: 100%;
    min-height: 160px;
    background: linear-gradient(145deg, #e3e6e6, #d5d9d9);
  }

  .bam-search__placeholder--article {
    min-height: 140px;
  }

  .bam-search__placeholder--page {
    min-height: 160px;
    background: linear-gradient(145deg, #232f3e, #131921);
  }

  .bam-search__meta {
    padding: 0.75rem 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .bam-search__type {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #007185;
  }

  .bam-search__item-title {
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.35;
    color: #0f1111;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bam-search__price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem;
    margin-top: auto;
  }

  .bam-search__price {
    font-size: 1rem;
    font-weight: 700;
    color: #0f1111;
  }

  .bam-search__price--sale {
    color: #b12704;
  }

  .bam-search__compare {
    font-size: 0.8125rem;
    color: #565959;
    text-decoration: line-through;
  }

  .bam-search__badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #565959;
  }

  .bam-pagination {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  .bam-pagination :is(span, a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    min-height: 2.25rem;
    margin: 0 0.15rem;
    padding: 0 0.5rem;
    font-size: 0.875rem;
    border-radius: 4px;
    text-decoration: none;
  }

  .bam-pagination a {
    color: #007185;
    background: #fff;
    border: 1px solid #d5d9d9;
  }

  .bam-pagination a:hover {
    background: #f0f2f2;
  }

  .bam-pagination .current,
  .bam-pagination span.current {
    font-weight: 700;
    color: #0f1111;
    background: #fff;
    border: 1px solid #febd69;
  }

  .bam-pagination .deco {
    border: none;
    background: transparent;
    color: #565959;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
